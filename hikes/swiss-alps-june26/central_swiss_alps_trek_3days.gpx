<gpx version="1.1" creator="Dinvest hike planner (BRouter hiking-mountain over OSM)" xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">
 <wpt lat="46.871983" lon="8.436010"><ele>1718</ele><name>D1.1 Chruzhutte (1718 m)</name><desc>Day 1 start - top of the Bannalp cable car. Head toward Bannalpsee. Follow signs: Walenpfad / Brunni.</desc></wpt>
 <wpt lat="46.868095" lon="8.443579"><name>D1.2 Urnerstafel</name><desc>Small alpine dairy farm near the lake where the ascent begins.</desc></wpt>
 <wpt lat="46.868713" lon="8.413333"><ele>1951</ele><name>D1.3 Walegg (1951 m)</name><desc>Highest point of Day 1. Steep zig-zag climb, then descent.</desc></wpt>
 <wpt lat="46.858402" lon="8.431870"><ele>1884</ele><name>D1.4 Oberfeld (1884 m)</name><desc>Alpine meadow with a small farm. Alp Oberfeld restaurant (goat cheese, meat, yoghurt).</desc></wpt>
 <wpt lat="46.838989" lon="8.422298"><ele>1716</ele><name>D1.5 Rigidalalp (1716 m)</name><desc>Mountain restaurant; trail levels out and widens.</desc></wpt>
 <wpt lat="46.831959" lon="8.407338"><ele>1600</ele><name>D1.6 Brunni / Ristis (1600 m)</name><desc>Day 1 end. Engelberg-Ristis cable car down to Engelberg (Ski Lodge). Fri 26 Jun 2026: 08:00-17:00 every 20 min; single CHF 20 (CHF 10 Half-Fare).</desc></wpt>
 <wpt lat="46.794033" lon="8.399545"><ele>1796</ele><name>D2.1 Trubsee (1796 m)</name><desc>Day 2 start (Titlis mid-station). Walk the left shore. Signs: Jochpass / Engstlenalp / Route 574.</desc></wpt>
 <wpt lat="46.777885" lon="8.386998"><ele>2207</ele><name>D2.2 Jochpass (2207 m)</name><desc>Steep climb to the pass - high point of Day 2. Chairlift shortcut from Trubsee.</desc></wpt>
 <wpt lat="46.776352" lon="8.379205"><ele>1850</ele><name>D2.3 Engstlensee (1850 m)</name><desc>Deep-blue second lake on the far side of the pass.</desc></wpt>
 <wpt lat="46.774147" lon="8.357228"><ele>1834</ele><name>D2.4 Engstlenalp (1834 m)</name><desc>Small settlement and hotel just past the lake.</desc></wpt>
 <wpt lat="46.779011" lon="8.319904"><ele>1976</ele><name>D2.5 / D3.2 Tannalp (1976 m)</name><desc>Third lake (Tannensee) and Berggasthaus Tannalp. Day 3 climb to Balmeregghorn begins here.</desc></wpt>
 <wpt lat="46.775928" lon="8.269320"><ele>1920</ele><name>D2.6 / D3.1 Melchsee-Frutt (1920 m)</name><desc>Day 2 end / Day 3 start. Night 2: Berghotel Distelboden. Day 3 walks east across the plateau.</desc></wpt>
 <wpt lat="46.759769" lon="8.293912"><name>D3.3 Erzegg</name><desc>Ridge station on the Day 3 climb; follow red-white-red markers along the mountainside.</desc></wpt>
 <wpt lat="46.753506" lon="8.282995"><ele>2255</ele><name>D3.4 Balmeregghorn (2255 m)</name><desc>Ridge crossing and hardest climb. Bernese Alps come into view - Eiger, Monch, Jungfrau.</desc></wpt>
 <wpt lat="46.737949" lon="8.256304"><ele>2245</ele><name>D3.5 Planplatten / Alpen tower (2245 m)</name><desc>Trek end. Gondolas down via Magisalp and Hasliberg Reuti to Meiringen, then train.</desc></wpt>
 <trk>
